        "# Simulação didática — folhas da B+ como lista encadeada\n",
        "\n",
        "class NoFolha:\n",
        "    def __init__(self, valores):\n",
        "        self.valores = valores\n",
        "        self.proxima = None  # O 'pulo do gato' da B+: folhas conectadas!\n",
        "\n",
        "# Montando as folhas manualmente para visualização\n",
        "folha1 = NoFolha([10, 15, 20])\n",
        "folha2 = NoFolha([25, 30, 35])\n",
        "folha3 = NoFolha([40, 45, 50])\n",
        "\n",
        "# Conectando como uma lista encadeada\n",
        "folha1.proxima = folha2\n",
        "folha2.proxima = folha3\n",
        "\n",
        "print('Estrutura das folhas conectadas:')\n",
        "print(f'  Folha 1: {folha1.valores}  --->  Folha 2: {folha2.valores}  --->  Folha 3: {folha3.valores}  ---> None')\n",
        "print()\n",
        "\n",
        "def busca_em_intervalo(inicio, fim, primeira_folha):\n",
        "    print(f'🔍 Buscando valores entre {inicio} e {fim}...')\n",
        "    resultados = []\n",
        "    folha_atual = primeira_folha\n",
        "    folha_num = 1\n",
        "\n",
        "    while folha_atual is not None:\n",
        "        print(f'   Verificando Folha {folha_num}: {folha_atual.valores}')\n",
        "        for valor in folha_atual.valores:\n",
        "            if inicio <= valor <= fim:\n",
        "                resultados.append(valor)\n",
        "        folha_atual = folha_atual.proxima  # pula para o próximo bloco!\n",
        "        folha_num += 1\n",
        "\n",
        "    print(f'✅ Valores encontrados: {resultados}')\n",
        "    return resultados\n",
        "\n",
        "busca_em_intervalo(15, 40, folha1)"
